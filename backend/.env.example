# Backend environment variables — copy to `.env` and fill in.
# NEVER commit the real .env (it is gitignored).

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# --- JWT ---
# Use a long random secret, e.g. `openssl rand -hex 48`
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION=15m
REFRESH_EXPIRATION=7d

# --- Admin bootstrap ---
# Used by ensureAdmin() on startup and by `npm run admin:rotate`.
# If LOGIN/PASSWORD are unset, no admin is created (no insecure default).
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_EMAIL=admin@example.com

# --- Media (Cloudinary) ---
# Image uploads respond 503 when unset; everything else keeps working.
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# --- Payments (Stripe) ---
# Paid ticket checkout responds 503 when unset; free events always work.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email ---
# Providers: console (default, logs only — dev/CI safe) | smtp | resend
EMAIL_PROVIDER=console
EMAIL_FROM="Event Platform <no-reply@example.com>"
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# RESEND_API_KEY=re_...

# --- CORS / frontend ---
FRONTEND_URL=https://localhost:8080

# --- Server ---
PORT=4000
NODE_ENV=development
